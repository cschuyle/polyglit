# Set this to load data from the local fixtures instead of from S3.
#export REACT_APP_USE_FIXTURES_FLAG=true

# Show Group By dropdown
#export REACT_APP_GROUP_BY_FLAG=true

# Show right-hand sort navigator when Group By is none
#export REACT_APP_SORT_NAV_FLAG=true

# Override which trove the root route (/) loads.
# Valid values: little-prince, hobbit, alice-in-wonderland, books
# You may also provide a comma-delimited list to show trove tabs on /
#export REACT_APP_TROVE_IDS=hobbit
#export REACT_APP_TROVE_IDS=little-prince,hobbit,books

# Show trove selector tabs in the header (requires REACT_APP_TROVE_DATA to list multiple troves)
#export REACT_APP_MULTI_TROVES_FLAG=true

